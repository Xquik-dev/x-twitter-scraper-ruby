        STORE_API_KEY_AND_THE_IDEMPOTENCY_KEY_SECURELY_BEFORE_SHARING_CHECKOUT_URL_NO_EMAIL_RECOVERY_IS_AVAILABLE: :"Store api_key and the Idempotency-Key securely before sharing checkout_url. No email recovery is available."


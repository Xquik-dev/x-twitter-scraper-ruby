        PENDING: :pending
        PAID: :paid
        EXPIRED: :expired
        FAILED: :failed
        REFUNDED: :refunded
        DISPUTED: :disputed

        def self?.values: -> ::Array[XTwitterScraper::Models::GuestWalletTopupResponse::status]
